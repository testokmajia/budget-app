.item{display:flex;justify-content:space-between;align-items:center;padding:24rpx 0;border-bottom:1rpx solid #f0f0f0}
.item:last-child{border-bottom:none}
.item-left{flex:1;display:flex;flex-direction:column;gap:8rpx}
.item-name{font-size:30rpx;font-weight:500}
.item-desc{font-size:24rpx;color:#909399;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.item-right{display:flex;align-items:center;gap:8rpx;flex-shrink:0}
.progress{font-size:26rpx;color:#409eff;font-weight:500}
.arrow{font-size:28rpx;color:#c0c4cc}
