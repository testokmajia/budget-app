.box{display:flex;flex-direction:column;align-items:center;padding:80rpx 40rpx;text-align:center}
.title{font-size:36rpx;font-weight:600;margin-bottom:20rpx}
.desc{font-size:28rpx;color:#606266;margin-bottom:40rpx;line-height:1.6}
.form{width:100%;display:flex;flex-direction:column;gap:20rpx}
.form input{border:1rpx solid #dcdfe6;border-radius:8rpx;padding:20rpx;font-size:28rpx;background:#fff;width:100%;box-sizing:border-box}
.error-text{color:#f56c6c;font-size:26rpx}
.btn-confirm{width:100%;background:#409eff;color:#fff;font-size:30rpx;padding:20rpx;border-radius:8rpx}
