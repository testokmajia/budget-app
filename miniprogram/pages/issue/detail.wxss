.info-row{display:flex;justify-content:space-between;padding:14rpx 0;border-bottom:1rpx solid #f0f0f0}
.info-row:last-child{border-bottom:none}
.info-label{color:#909399;font-size:26rpx;flex-shrink:0}
.info-value{color:#303133;font-size:26rpx;text-align:right}
.info-block{padding:20rpx 0;border-bottom:1rpx solid #f0f0f0}
.info-text{display:block;margin-top:10rpx;font-size:26rpx;color:#606266;line-height:1.6}
.log-item{display:flex;gap:16rpx;padding-bottom:24rpx;position:relative}
.log-item:not(:last-child)::before{content:'';position:absolute;left:7rpx;top:16rpx;bottom:-24rpx;width:2rpx;background:#ebeef5}
.log-dot{width:16rpx;height:16rpx;border-radius:50%;background:#409eff;flex-shrink:0;margin-top:6rpx}
.log-content{flex:1}
.log-header{display:flex;justify-content:space-between;align-items:center}
.log-action{font-size:28rpx;font-weight:500}
.log-time{font-size:22rpx;color:#c0c4cc}
.log-remark{display:block;font-size:26rpx;color:#606266;margin-top:8rpx}
.log-operator{font-size:24rpx;color:#909399;margin-top:6rpx;display:block}
